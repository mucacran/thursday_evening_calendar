@page "/addEvent"
@rendermode InteractiveServer
@inject HttpClient Http
@using System.Text.Json

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Add Meeting</h4>
                </div>
                <div class="card-body">

                    <EditForm Model="@eventModel" OnValidSubmit="HandleValidSubmit" FormName="AddEventForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger mb-3" />

                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="eventModel.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Course</label>
                            <InputSelect class="form-select" @bind-Value="eventModel.CourseId">
                                <option value="0">0 - No course</option>
                                @foreach (var course in courses)
                                {
                                    <option value="@course.Id">@course.Id - @course.Name</option>
                                }
                            </InputSelect>
                            @if (courses.Count == 0)
                            {
                                <small class="text-muted">No courses found. Use 0 to save without course.</small>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Date</label>
                            <InputDate class="form-control"
                                       Type="InputDateType.DateTimeLocal"
                                       @bind-Value="eventModel.Date" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" rows="3"
                                           @bind-Value="eventModel.Description" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Add Event
                        </button>
                    </EditForm>

                    @if (!string.IsNullOrEmpty(message))
                    {
                        <div class="alert mt-3 @(message.Contains("success") ? "alert-success" : "alert-danger")">
                            @message
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private EventModel eventModel = new();
    private string? message;
    private List<CourseOption> courses = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            courses = await Http.GetFromJsonAsync<List<CourseOption>>("api/events/courses") ?? new List<CourseOption>();
        }
        catch
        {
            courses = new List<CourseOption>();
        }
    }

    private async Task HandleValidSubmit()
    {
        message = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/events", eventModel);

            if (response.IsSuccessStatusCode)
            {
                message = "Event added successfully!";
                eventModel = new EventModel(); // reset form
                return;
            }

            var errorBody = await response.Content.ReadAsStringAsync();
            var parsedMessage = ExtractErrorMessage(errorBody);
            message = $"Error: {parsedMessage}";
        }
        catch (Exception ex)
        {
            message = $"Error: No se pudo enviar el formulario. {ex.Message}";
        }
    }

    private static string ExtractErrorMessage(string body)
    {
        if (string.IsNullOrWhiteSpace(body))
        {
            return "Sin detalle devuelto por el servidor.";
        }

        try
        {
            using var doc = JsonDocument.Parse(body);
            var root = doc.RootElement;

            if (root.TryGetProperty("message", out var messageValue) &&
                messageValue.ValueKind == JsonValueKind.String)
            {
                return messageValue.GetString() ?? "Error desconocido.";
            }

            if (root.TryGetProperty("title", out var titleValue) &&
                titleValue.ValueKind == JsonValueKind.String)
            {
                return titleValue.GetString() ?? "Error desconocido.";
            }
        }
        catch
        {
            // Ignore parse errors and fall back to raw text.
        }

        return body;
    }

    private class CourseOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
